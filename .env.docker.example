# Copy to `.env` in the repo root (gitignored) before `docker compose up`.
# Never commit real keys.
# Full playbook: docs/DOCKER.md

# Zen / Go upstream (optional — seeds providers when set)
OPENCODE_API_KEY=

# Gateway password for clients (Bearer / x-api-key). Required for network mode.
RELAY_AI_SERVER_PASSWORD=

# Optional: LAN IP(s) for URL cards (Docker only sees 172.x bridge otherwise).
# If unset, the admin UI uses the Host you opened it with (e.g. http://192.168.1.10:8787).
# RELAY_AI_ADVERTISE_HOST=192.168.1.10
# RELAY_AI_ADVERTISE_HOSTS=192.168.1.10,10.0.0.5

# Host-published ports (left side of Compose publish). Defaults 8787 / 17645.
# RELAY_AI_UI_HOST_PORT=8787
# RELAY_AI_GATEWAY_HOST_PORT=17645

# Optional UI listen port inside the container (default 8787)
# RELAY_AI_UI_PORT=8787

# Optional per-provider keys (override keyring / authRef). Pattern:
#   RELAY_AI_KEY_<PROVIDER_ID_UPPERCASE_WITH_UNDERSCORES>
# Examples:
# RELAY_AI_KEY_GROQ=
# RELAY_AI_KEY_OPENAI=
# RELAY_AI_KEY_DEEPSEEK=
# RELAY_AI_KEY_OPENROUTER=
